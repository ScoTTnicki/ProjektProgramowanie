<Window x:Class="ProjektProgramowanie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Macierz Ryzyka IT" Height="820" Width="1280"
        MinHeight="650" MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Loaded="MainWindow_Loaded">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- LEWA KOLUMNA: FORMULARZ (w ScrollViewer, żeby przyciski nigdy się nie ucinały) -->
        <ScrollViewer Grid.Column="0" Margin="0,0,15,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Dodaj / edytuj ryzyko" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <TextBlock Text="Nazwa zagrożenia:"/>
                <TextBox x:Name="TxtName" Margin="0,5,0,15" Height="25" Padding="2"/>

                <TextBlock Text="Właściciel ryzyka:"/>
                <TextBox x:Name="TxtOwner" Margin="0,5,0,15" Height="25" Padding="2"/>

                <TextBlock Text="Kategoria:"/>
                <ComboBox x:Name="CmbCategory" Margin="0,5,0,15" Height="25"/>

                <TextBlock Text="Status:"/>
                <ComboBox x:Name="CmbStatus" Margin="0,5,0,15" Height="25"/>

                <TextBlock Text="Prawdopodobieństwo (1-5):" FontWeight="SemiBold"/>
                <Slider x:Name="SldProbability" Minimum="1" Maximum="5" Value="1" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,5,0,5"/>
                <TextBlock Text="{Binding ElementName=SldProbability, Path=Value}" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="Skutek / Wpływ (1-5):" FontWeight="SemiBold"/>
                <Slider x:Name="SldImpact" Minimum="1" Maximum="5" Value="1" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,5,0,5"/>
                <TextBlock Text="{Binding ElementName=SldImpact, Path=Value}" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,20"/>

                <Button x:Name="BtnAdd" Content="Dodaj Ryzyko do Listy" Height="35" Click="BtnAdd_Click" Background="#FF0078D7" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                <Button Content="Edytuj zaznaczone ryzyko" Height="35" Click="BtnEdit_Click" Background="#FF8764B8" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                <Button Content="Anuluj edycję" Height="30" Click="BtnCancelEdit_Click" Background="#FFA0A0A0" Foreground="White" Margin="0,0,0,10"/>
                <Button Content="Usuń zaznaczone ryzyko" Height="35" Click="BtnDelete_Click" Background="#FFD83B01" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                <Button Content="Zapisz dane do pliku JSON" Height="35" Click="BtnSave_Click" Background="#FF107C10" Foreground="White" FontWeight="Bold" Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ŚRODEK: FILTR + TABELA -->
        <DockPanel Grid.Column="1" Margin="0,0,15,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Filtruj wg statusu:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="CmbFilterStatus" Width="180" Height="25" SelectionChanged="CmbFilterStatus_SelectionChanged"/>
            </StackPanel>

            <DataGrid x:Name="DgRisks" AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" CanUserSortColumns="True"
                      AlternatingRowBackground="#FFF0F0F0" HeadersVisibility="Column"
                      SelectionMode="Single" SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Name}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Właściciel" Binding="{Binding Owner}" Width="120"/>
                    <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}" Width="130"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                    <DataGridTextColumn Header="Utworzono" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Punktacja" Binding="{Binding Score}" Width="95"/>
                    <DataGridTextColumn Header="Poziom Ryzyka" Binding="{Binding RiskLevel}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- PRAWA KOLUMNA: MACIERZ RYZYKA + KOMUNIKAT + LOGO + POGODA -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Macierz ryzyka" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Wiersze: Prawdopodobieństwo, Kolumny: Skutek/Wpływ"
                           TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,0,0,10"/>

                <TextBlock Text="Skutek / Wpływ →" FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="24,0,0,4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Prawdopodobieństwo ↑" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="-90"/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="6"
                            BorderBrush="#FFE0E0E0" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                        </Border.Effect>
                        <Grid x:Name="RiskMatrixGrid" Height="240"/>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Background="#FF81C784" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                    <TextBlock Text="Niskie" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="12"/>
                    <Border Background="#FFFFD54F" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                    <TextBlock Text="Średnie" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="12"/>
                    <Border Background="#FFE57373" Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"/>
                    <TextBlock Text="Wys./Kryt." VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <!-- DYNAMICZNY KOMUNIKAT O STANIE RYZYKA -->
                <Border x:Name="BorderRiskStatus" CornerRadius="8" Padding="12" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtRiskStatusTitle" FontWeight="Bold" FontSize="13"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtRiskStatusDetail" FontSize="11.5"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="TxtEditingInfo" Margin="0,15,0,0" TextWrapping="Wrap"
                           FontStyle="Italic" Foreground="#FF8764B8" Visibility="Collapsed"/>

                <!-- LOGO -->
                <Border BorderThickness="0,1,0,0" BorderBrush="#FFE0E0E0" Margin="0,30,0,15" Padding="0,18,0,0">
                    <svgc:SvgViewbox Source="Assets/mainlogo.svg" Width="230" Stretch="Uniform" HorizontalAlignment="Center"/>
                </Border>

                <!-- WIDGET POGODOWY (Open-Meteo API) -->
                <Border Background="#FFF5F5F5" CornerRadius="10" Padding="14" Margin="0,0,0,15"
                        BorderBrush="#FFE0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Warunki pogodowe – Rzeszów" FontSize="12" FontWeight="SemiBold"
                                   Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtWeatherIcon" Text="⏳" FontSize="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock x:Name="TxtWeatherTemp" Text="--" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtWeatherDescription" Text="Ładowanie..." FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock x:Name="TxtWeatherWind" Text="" FontSize="10.5" Foreground="Gray"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>

                        <TextBlock x:Name="TxtWeatherWarning" Text="" FontSize="10.5" Foreground="#FFD32F2F"
                                   FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>